  totalQty          Decimal  @default(0) @map("total_qty") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  lokasiAsal      LokasiStok       @relation("MutasiLokasiAsal", fields: [lokasiAsalId], references: [id], onDelete: Restrict)
  lokasiTujuan    LokasiStok       @relation("MutasiLokasiTujuan", fields: [lokasiTujuanId], references: [id], onDelete: Restrict)
  penanggungJawab User?            @relation("MutasiPenanggungJawab", fields: [penanggungJawabId], references: [id], onDelete: SetNull)
  items           MutasiStokItem[]

  @@index([lokasiAsalId])
  @@index([lokasiTujuanId])
  @@index([penanggungJawabId])
  @@map("t_mutasi_stok")
