model MutasiStokItem {
  id            String  @id @default(cuid())
  mutasiStokId  String  @map("mutasi_stok_id")
  sparepartId   String? @map("sparepart_id")
  namaSparepart String  @map("nama_sparepart") @db.VarChar(180)
  stokAsal      Int?    @map("stok_asal")
  qtyMutasi     Decimal @default(0) @map("qty_mutasi") @db.Decimal(12, 2)
  satuan        String? @db.VarChar(40)
  catatan       String? @db.Text

  mutasiStok MutasiStok @relation(fields: [mutasiStokId], references: [id], onDelete: Cascade)
  sparepart  Sparepart? @relation(fields: [sparepartId], references: [id], onDelete: SetNull)

  @@index([mutasiStokId])
  @@index([sparepartId])
  @@map("t_mutasi_stok_item")
}

model StokLedger {
  id          String           @id @default(cuid())
  tanggal     DateTime         @default(now())
  sparepartId String           @map("sparepart_id")
  lokasiId    String?          @map("lokasi_id")
  tipe        StokMovementType
  qtyMasuk    Decimal          @default(0) @map("qty_masuk") @db.Decimal(12, 2)
  qtyKeluar   Decimal          @default(0) @map("qty_keluar") @db.Decimal(12, 2)
  stokSebelum Decimal          @default(0) @map("stok_sebelum") @db.Decimal(12, 2)
  stokSesudah Decimal          @default(0) @map("stok_sesudah") @db.Decimal(12, 2)
  satuan      String?          @db.VarChar(40)
  hargaModal  Decimal          @default(0) @map("harga_modal") @db.Decimal(14, 2)
  refTipe     String?          @map("ref_tipe") @db.VarChar(80)
  refId       String?          @map("ref_id")
  refNo       String?          @map("ref_no") @db.VarChar(80)
  catatan     String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")

  sparepart Sparepart   @relation(fields: [sparepartId], references: [id], onDelete: Restrict)
  lokasi    LokasiStok? @relation(fields: [lokasiId], references: [id], onDelete: SetNull)

  @@index([sparepartId])
  @@index([lokasiId])
  @@index([refTipe, refId])
  @@map("t_stok_ledger")
}

// -----------------------------------------------------------------------------
// TRANSAKSI KEUANGAN - t_ prefix
// -----------------------------------------------------------------------------

model Invoice {
  id             String        @id @default(cuid())
  noInvoice      String        @unique @map("no_invoice") @db.VarChar(40)
  workOrderId    String?       @unique @map("work_order_id")
  pelangganId    String        @map("pelanggan_id")
  kendaraanId    String?       @map("kendaraan_id")
  tanggalInvoice DateTime      @map("tanggal_invoice")
  jatuhTempo     DateTime?     @map("jatuh_tempo")
  status         InvoiceStatus @default(DRAFT)
  totalJasa      Decimal       @default(0) @map("total_jasa") @db.Decimal(16, 2)
  totalSparepart Decimal       @default(0) @map("total_sparepart") @db.Decimal(16, 2)
  totalLainnya   Decimal       @default(0) @map("total_lainnya") @db.Decimal(16, 2)
  grandTotal     Decimal       @default(0) @map("grand_total") @db.Decimal(16, 2)
  terbayar       Decimal       @default(0) @db.Decimal(16, 2)
  sisaTagihan    Decimal       @default(0) @map("sisa_tagihan") @db.Decimal(16, 2)
  catatan        String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  workOrder  WorkOrder?    @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  pelanggan  Pelanggan     @relation(fields: [pelangganId], references: [id], onDelete: Restrict)
  kendaraan  Kendaraan?    @relation(fields: [kendaraanId], references: [id], onDelete: SetNull)
  items      InvoiceItem[]
  pembayaran Pembayaran[]
  piutang    Piutang?

  @@index([pelangganId])
  @@index([kendaraanId])
  @@map("t_invoice")
}

model InvoiceItem {
  id           String          @id @default(cuid())
  invoiceId    String          @map("invoice_id")
  tipe         InvoiceItemTipe
  deskripsi    String          @db.VarChar(180)
  jasaServisId String?         @map("jasa_servis_id")
  sparepartId  String?         @map("sparepart_id")
  qty          Decimal         @default(1) @db.Decimal(12, 2)
  harga        Decimal         @default(0) @db.Decimal(14, 2)
  subtotal     Decimal         @default(0) @db.Decimal(16, 2)

  invoice    Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  jasaServis JasaServis? @relation(fields: [jasaServisId], references: [id], onDelete: SetNull)
  sparepart  Sparepart?  @relation(fields: [sparepartId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([jasaServisId])
  @@index([sparepartId])
  @@map("t_invoice_item")
}

model Pembayaran {
  id                 String           @id @default(cuid())
  noPembayaran       String           @unique @map("no_pembayaran") @db.VarChar(40)
  invoiceId          String           @map("invoice_id")
  pelangganId        String?          @map("pelanggan_id")
  tanggal            DateTime
  metodePembayaranId String?          @map("metode_pembayaran_id")
  akunKasBankId      String?          @map("akun_kas_bank_id")
  jumlahBayar        Decimal          @default(0) @map("jumlah_bayar") @db.Decimal(16, 2)
  nomorReferensi     String?          @map("nomor_referensi") @db.VarChar(120)
  kasirId            String?          @map("kasir_id")
  status             PembayaranStatus @default(SELESAI)
  catatan            String?          @db.Text
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  invoice          Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  pelanggan        Pelanggan?        @relation(fields: [pelangganId], references: [id], onDelete: SetNull)
  metodePembayaran MetodePembayaran? @relation(fields: [metodePembayaranId], references: [id], onDelete: SetNull)
  akunKasBank      AkunKasBank?      @relation(fields: [akunKasBankId], references: [id], onDelete: SetNull)
  kasir            User?             @relation("PembayaranKasir", fields: [kasirId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([pelangganId])
  @@index([metodePembayaranId])
  @@index([akunKasBankId])
  @@index([kasirId])
  @@map("t_pembayaran")
}

model Piutang {
  id           String        @id @default(cuid())
  invoiceId    String        @unique @map("invoice_id")
  pelangganId  String        @map("pelanggan_id")
  tanggal      DateTime
  jatuhTempo   DateTime?     @map("jatuh_tempo")
  totalTagihan Decimal       @default(0) @map("total_tagihan") @db.Decimal(16, 2)
  terbayar     Decimal       @default(0) @db.Decimal(16, 2)
  sisaPiutang  Decimal       @default(0) @map("sisa_piutang") @db.Decimal(16, 2)
  status       PiutangStatus @default(BELUM_LUNAS)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  pelanggan Pelanggan @relation(fields: [pelangganId], references: [id], onDelete: Restrict)

  @@index([pelangganId])
  @@map("t_piutang")
}

model KasBankTransaksi {
  id            String       @id @default(cuid())
  noTransaksi   String       @unique @map("no_transaksi") @db.VarChar(40)
  tanggal       DateTime
  jenis         KasBankJenis
  kategori      String       @db.VarChar(120)
  deskripsi     String?      @db.Text
  jumlah        Decimal      @default(0) @db.Decimal(16, 2)
  akunKasBankId String       @map("akun_kas_bank_id")
  saldoAkhir    Decimal      @default(0) @map("saldo_akhir") @db.Decimal(16, 2)
  refTipe       String?      @map("ref_tipe") @db.VarChar(80)
  refId         String?      @map("ref_id")
  refNo         String?      @map("ref_no") @db.VarChar(80)
  createdById   String?      @map("created_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  akunKasBank AkunKasBank @relation(fields: [akunKasBankId], references: [id], onDelete: Restrict)
  createdBy   User?       @relation("KasBankCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([akunKasBankId])
  @@index([createdById])
  @@index([refTipe, refId])
  @@map("t_kas_bank")
}
