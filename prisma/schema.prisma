model StokMasukItem {
  id            String  @id @default(cuid())
  stokMasukId   String  @map("stok_masuk_id")
  sparepartId   String? @map("sparepart_id")
  namaSparepart String  @map("nama_sparepart") @db.VarChar(180)
  qtyMasuk      Decimal @default(0) @map("qty_masuk") @db.Decimal(12, 2)
  satuan        String? @db.VarChar(40)
  hargaModal    Decimal @default(0) @map("harga_modal") @db.Decimal(14, 2)
  subtotal      Decimal @default(0) @db.Decimal(16, 2)
  catatan       String? @db.Text

  stokMasuk StokMasuk  @relation(fields: [stokMasukId], references: [id], onDelete: Cascade)
  sparepart Sparepart? @relation(fields: [sparepartId], references: [id], onDelete: SetNull)

  @@index([stokMasukId])
  @@index([sparepartId])
