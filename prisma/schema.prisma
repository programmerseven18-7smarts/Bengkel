  stokSaatItu   Int?    @map("stok_saat_itu")
  qtyKeluar     Decimal @default(0) @map("qty_keluar") @db.Decimal(12, 2)
  satuan        String? @db.VarChar(40)
  hargaModal    Decimal @default(0) @map("harga_modal") @db.Decimal(14, 2)
  subtotal      Decimal @default(0) @db.Decimal(16, 2)
  catatan       String? @db.Text

  stokKeluar StokKeluar @relation(fields: [stokKeluarId], references: [id], onDelete: Cascade)
  sparepart  Sparepart? @relation(fields: [sparepartId], references: [id], onDelete: SetNull)

  @@index([stokKeluarId])
  @@index([sparepartId])
  @@map("t_stok_keluar_item")
}

model MutasiStok {
  id                String   @id @default(cuid())
  noMutasi          String   @unique @map("no_mutasi") @db.VarChar(40)
  tanggal           DateTime
  lokasiAsalId      String   @map("lokasi_asal_id")
  lokasiTujuanId    String   @map("lokasi_tujuan_id")
  penanggungJawabId String?  @map("penanggung_jawab_id")
